# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env
.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Project-specific
*.log
api_keys.txt
benchmark_results.json.bak

# SQLite WAL auxiliary files (transient — only present while a connection is open
# or a write is uncheckpointed; safe to ignore, the .db file is the source of truth).
*.db-shm
*.db-wal

# Pytest
.pytest_cache/

# Project data — local DB backups, dry-run DB, and transient logs gitignored.
# data/schema.sql IS the source of truth for table shape and stays tracked.
# data/results.db is committed at v1 ship time as the public benchmark
# artefact (1,280 rows × 4 levers × judge scores) — the writeup cites it
# directly. Backups (.bak-*), the Day 6 dry-run DB, and transient logs
# (.jsonl) remain gitignored.
data/*.db
!data/results.db
data/*.db.bak*
data/*.jsonl

# Local agent state
.claude/
