# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env
.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Project-specific
*.log
api_keys.txt
benchmark_results.json.bak

# SQLite WAL auxiliary files (transient — only present while a connection is open
# or a write is uncheckpointed; safe to ignore, the .db file is the source of truth).
*.db-shm
*.db-wal

# Pytest
.pytest_cache/

# Project data — .db files are run-specific empirical results, not source.
# data/schema.sql IS the source of truth for table shape and stays tracked.
data/*.db
data/*.db.bak*
data/*.jsonl

# Local agent state
.claude/
