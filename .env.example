# LLM Cost Benchmark 2026 — environment template.
# Copy to .env (gitignored) and fill in real values. Never commit .env.

# Anthropic — used for Sonnet 4.6 + Haiku 4.5 model runs and Opus 4.6 Judge A.
ANTHROPIC_API_KEY=

# OpenAI — used for GPT-4o + GPT-4o-mini model runs.
OPENAI_API_KEY=

# Mistral — used for Judge B (Mistral Large) in Tier 2 dual-judge scoring.
MISTRAL_API_KEY=

# Concurrency for runners. Default 4. Raise if rate limits permit.
INFEROPS_CONCURRENCY=4
