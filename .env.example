# LLM Cost Benchmark 2026 — environment template.
# Copy to .env (gitignored) and fill in real values. Never commit .env.

# Anthropic — used for Sonnet 4.6 + Haiku 4.5 model runs and Opus 4.6 Judge A (Tier 2).
ANTHROPIC_API_KEY=

# OpenAI — used for GPT-5.4 + GPT-5.4-mini model runs and GPT-5.5 Judge B (Tier 2 panel after Day 11 revision).
OPENAI_API_KEY=

# Mistral — used for the original v1 Judge B (replaced by GPT-5.5 in Day 11 panel revision).
# Integration retained for v2 cross-judge analysis. Optional for v1 reproduction.
MISTRAL_API_KEY=

# Gemini — integration retained for v2 evaluation; not used in v1 production sweep.
# Optional for v1 reproduction.
GEMINI_API_KEY=

# Concurrency for runners. Default 4. Raise if rate limits permit.
INFEROPS_CONCURRENCY=4
